{
  "expo": {
    "name": "Auram",
    "slug": "auram",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "auram",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.auram.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "Auram, size kişiselleştirilmiş parfüm önerileri sunabilmek için reklam tercihlerinizi analiz etmek amacıyla cihaz tanımlayıcınızı kullanmak istiyor.",
        "GADApplicationIdentifier": "ca-app-pub-1731461024871182~9770094099",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#D4A574",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.auram.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#D4A574",
          "dark": {
            "backgroundColor": "#1A1A26"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1731461024871182~1620940090",
          "iosAppId": "ca-app-pub-1731461024871182~9770094099"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6014341b-6267-4d19-a435-936ae2dda0ab"
      }
    },
    "owner": "yusufizzetgenc"
  }
}
