{
  "expo": {
    "name": "Auram",
    "slug": "auram",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "auram",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.auram.app",
      "buildNumber": "7",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "Sizin ilgi alanlarınıza göre kişiselleştirilmiş reklamlar sunabilmek için bu izne ihtiyacımız var.",
        "NSLocationWhenInUseUsageDescription": "Auram, bulunduğunuz bölgenin hava durumuna ve mevsime en uygun parfüm önerilerini sunabilmek için konum verinize ihtiyaç duyar.",
        "NSLocationAlwaysUsageDescription": "Auram, bulunduğunuz bölgenin hava durumuna ve mevsime en uygun parfüm önerilerini sunabilmek için konum verinize ihtiyaç duyar.",
        "GADApplicationIdentifier": "ca-app-pub-1731461024871182~9770094099",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#D4A574",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.auram.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#D4A574",
          "dark": {
            "backgroundColor": "#1A1A26"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1731461024871182~1620940090",
          "iosAppId": "ca-app-pub-1731461024871182~9770094099"
        }
      ],
      "expo-tracking-transparency"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6014341b-6267-4d19-a435-936ae2dda0ab"
      }
    },
    "owner": "yusufizzetgenc"
  }
}
